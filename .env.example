# Copia este archivo a ".env" y rellena los valores.
# El backend funciona SIN key (modo demo). Con key usa datos reales.

# API key de API-Football (api-sports.io). Free tier: regístrate y cópiala.
# Sin esta variable, el scanner muestra datos demo que se auto-actualizan.
APIFOOTBALL_KEY=

# Puerto HTTP (Render/Railway lo inyectan automáticamente).
PORT=3000

# Milisegundos entre consultas al proveedor.
# OJO free tier = 100 req/día → usa 900000 (15 min) o deja modo demo.
# Con plan Pro puedes bajarlo a 60000 (1 min).
POLL_INTERVAL=60000

# Pon "1" para forzar modo demo aunque haya key.
FORCE_DEMO=

# ---- Fase 2: motor en vivo + Telegram ----
# Sin estas variables, el motor en vivo y Telegram quedan OFF (la web sigue
# funcionando como scanner demo). Cuando las pongas, el backend lee tus
# estrategias activas, las evalúa y envía alertas.

# Supabase (la URL es pública; la SERVICE KEY es SECRETA → solo aquí/Render).
SUPABASE_URL=https://eeqttlazijazoqtbbjiq.supabase.co
SUPABASE_SERVICE_KEY=

# Bot de Telegram (créalo con @BotFather).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

